# Template of environment variables required by the MealTimes backend.
# Copy this to ".env" and fill in real values for local development.
# On Render, set the same keys in the service's Environment settings.
# .NET maps nested config sections with a double underscore (Section__Key).

# ---- Runtime ----
ASPNETCORE_ENVIRONMENT=Development

# ---- Database (Neon PostgreSQL) ----
# Use the FULL Neon connection string, including the ".c-N." host segment and query params.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.c-N.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ---- CORS (comma-separated frontend origins allowed to call the API) ----
AllowedOrigins=http://localhost:5173

# ---- JWT ----
JwtSettings__Key=replace-with-a-long-random-secret-at-least-32-chars
JwtSettings__Issuer=MealTimesApi
JwtSettings__Audience=MealTimesClient
JwtSettings__ExpiryMinutes=60

# ---- Stripe ----
Stripe__SecretKey=sk_test_xxx
Stripe__PublicKey=pk_test_xxx

# ---- Email (SMTP) ----
EmailSettings__SmtpHost=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__FromEmail=your-email@gmail.com
EmailSettings__FromPassword=your-app-password
EmailSettings__FromName=MealTimes Support

# ---- App ----
AppSettings__BaseUrl=http://localhost:5173
